# PhotonicTag environment variables.
# Copy this file to .env.local and fill in real values. Never commit .env.local.
#
# Staging / production: Fly.io (`fly.toml`, `fly.staging.toml`). Non-secret defaults
# are in those files; secrets use `fly secrets set` on each app. CI runs
# `npm run db:push` then `flyctl deploy` (see `.github/workflows/deploy.yml`).
# EU bootstrap guide: `docs/hosting-bootstrap.md`.

# ─── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@host:5432/photonictag
SESSION_SECRET=change-me-to-a-long-random-string

# Comma-separated list of emails with master admin rights.
MASTER_ADMIN_EMAILS=admin@yourcompany.com

# Base URL used in outbound emails and OAuth redirects.
APP_BASE_URL=https://app.photonictag.example

# HMAC key for the audit log chain. 32+ random bytes, base64 or hex.
AUDIT_CHAIN_HMAC_KEY=change-me

# ─── AI provider (pick one) ────────────────────────────────────────────────
# openai | mistral | scaleway | azure-openai | custom
# Default: openai (backwards-compatible if unset).
AI_PROVIDER=mistral

# Mistral La Plateforme — https://console.mistral.ai/
# Paste your key in .env.local (not here). Never commit the real key.
AI_API_KEY=

# Optional overrides (the factory picks sensible defaults per provider):
# AI_BASE_URL=https://api.mistral.ai/v1
# AI_CHAT_MODEL=mistral-large-latest
# AI_MINI_MODEL=mistral-small-latest

# Legacy OpenAI fallbacks — still read if AI_API_KEY isn't set.
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# ─── SAP connector encryption ──────────────────────────────────────────────
# 32 bytes as 64 hex chars. Generate with: openssl rand -hex 32
CONNECTOR_ENCRYPTION_KEY=

# ─── Email ─────────────────────────────────────────────────────────────────
# Pick Brevo EU (free tier: 300/day) or any SMTP provider.
EMAIL_TIMEZONE=Europe/Berlin
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Brevo transactional email (EU, GDPR-friendly). Leave BREVO_API_KEY blank in
# dev to stub emails to the console.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@photonictag.com

# ─── Auth provider ─────────────────────────────────────────────────────────
# Fly staging/prod configs use workos (see fly.toml / fly.staging.toml).
AUTH_PROVIDER=workos

# WorkOS (required when AUTH_PROVIDER=workos — set in Fly secrets for deployed apps)
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# WORKOS_REDIRECT_URI=https://your-host.fly.dev/api/callback
