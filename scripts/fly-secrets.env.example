# Copy this file to fly-secrets.staging.env and fly-secrets.prod.env
# (both gitignored by .env.* rule). Fill in real values. NEVER commit these
# filled files or paste their contents into chat.
#
# Generate cryptographic values locally:
#   SESSION_SECRET           openssl rand -base64 48
#   AUDIT_CHAIN_HMAC_KEY     openssl rand -base64 48
#   CONNECTOR_ENCRYPTION_KEY openssl rand -hex 32
#
# Use a DIFFERENT set of crypto values for prod vs staging.

DATABASE_URL="postgresql://<user>:<pass>@<neon-host>/<db>?sslmode=require"
SESSION_SECRET=""
AUDIT_CHAIN_HMAC_KEY=""
CONNECTOR_ENCRYPTION_KEY=""
AI_API_KEY=""
MASTER_ADMIN_EMAILS="db@photonictag.com"

# Optional (leave blank to use in-process fallback)
REDIS_URL=""

# Optional — WorkOS (only fill when AUTH_PROVIDER=workos)
WORKOS_API_KEY=""
WORKOS_CLIENT_ID=""
WORKOS_REDIRECT_URI=""
